datasource db {
  url      = env("DATABASE_URL")
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model Bike {
  id          Int        @unique @default(autoincrement())
  candidateId Int
  name        String
  type        String
  bodySize    Int
  maxLoad     Int
  rate        Int
  description String     @db.VarChar(200)
  ratings     Float
  imageUrls   ImageUrl[]
  rental      Rental[]
  candidate   Candidate  @relation(fields: [candidateId], references: [id])

  @@id([id, candidateId])
}

model ImageUrl {
  id     Int    @unique @default(autoincrement())
  bikeId Int
  url    String
  bike   Bike   @relation(fields: [bikeId], references: [id])

  @@id([id, bikeId])
}

model User {
  id          Int       @unique @default(autoincrement())
  candidateId Int
  name        String
  email       String    @unique
  password    String
  rental      Rental[]
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@id([id, candidateId])
}

model Candidate {
  id      Int    @id @default(autoincrement())
  name    String
  email   String @unique
  token   String @unique
  users   User[]
  bikes   Bike[]
  rental  Rental[]
}

model Rental {
  id          Int       @id @default(autoincrement())
  candidateId Int
  bikeId      Int
  userId      Int
  startDate   DateTime
  endDate     DateTime
  rate        Int
  serviceFee  Decimal
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  bike        Bike      @relation(fields: [bikeId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}
